{
  "name": "gh-issue-lease",
  "version": "0.3.0",
  "description": "Atomic, GitHub-native mutex for multi-agent work. The lock IS a git ref — no server, no database. First writer wins.",
  "type": "module",
  "bin": {
    "gh-issue-lease": "dist/issue-lease.mjs"
  },
  "exports": {
    ".": "./dist/issue-lease.mjs"
  },
  "files": [
    "dist/issue-lease.mjs",
    "hooks/pre-push"
  ],
  "scripts": {
    "build": "esbuild src/issue-lease.mjs --bundle --minify --format=esm --platform=node --legal-comments=none --outfile=dist/issue-lease.mjs && chmod +x dist/issue-lease.mjs",
    "prepack": "npm run build",
    "test": "node --test"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "lock",
    "mutex",
    "lease",
    "github",
    "git",
    "agents",
    "multi-agent",
    "coordination",
    "distributed-lock",
    "gh",
    "issues"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codyrobertson/gh-issue-lease.git"
  },
  "bugs": {
    "url": "https://github.com/codyrobertson/gh-issue-lease/issues"
  },
  "homepage": "https://github.com/codyrobertson/gh-issue-lease#readme",
  "author": "Mackenzie Robertson <digitalcody@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
